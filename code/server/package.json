{
  "name": "@tower/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsc -p tsconfig.json && node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "tsc -p tsconfig.json && node --test dist/modules/tasks/*.test.js",
    "test:integration": "tsc -p tsconfig.json && node --test dist/test/v0.integration.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "node scripts/prisma-with-env.mjs generate",
    "prisma:migrate": "node scripts/apply-sql-migrations.mjs",
    "prisma:seed": "tsc --target ES2022 --module NodeNext --moduleResolution NodeNext --esModuleInterop --skipLibCheck --outDir dist-prisma prisma/seed.ts && node dist-prisma/seed.js",
    "prisma:test-tasks": "tsc --target ES2022 --module NodeNext --moduleResolution NodeNext --esModuleInterop --skipLibCheck --outDir dist-prisma prisma/generate-test-tasks.ts && node dist-prisma/generate-test-tasks.js",
    "prisma:studio": "node scripts/prisma-with-env.mjs studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@tower/shared": "0.1.0",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "pino-pretty": "^11.2.1",
    "prisma": "^6.19.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
