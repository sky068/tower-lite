{
  "name": "tower-lite",
  "version": "1.5.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "dev:up": "node scripts/dev-up.mjs",
    "dev:down": "node scripts/dev-down.mjs",
    "dev:init": "npm run docker:up && npm run prisma:migrate && npm run prisma:seed",
    "dev:reset": "node scripts/dev-reset.mjs",
    "dev:all": "npm run dev:init && npm run dev:up",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "deploy:up": "node scripts/deploy-up.mjs",
    "deploy:up:seed": "node scripts/deploy-up.mjs --seed",
    "deploy:down": "node scripts/deploy-down.mjs",
    "deploy:down:volumes": "node scripts/deploy-down.mjs --volumes",
    "deploy:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "build": "npm run build --workspaces",
    "doctor": "node scripts/doctor.mjs",
    "test": "npm run test --workspace server",
    "test:integration": "npm run test:integration --workspace server",
    "test:e2e": "playwright test",
    "test:e2e:reuse": "PLAYWRIGHT_REUSE_EXISTING_SERVER=1 playwright test",
    "test:acceptance": "npm run test:integration && npm run test:e2e",
    "test:acceptance:reuse": "npm run test:integration && npm run test:e2e:reuse",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "npm run lint --workspaces",
    "check:v0": "node scripts/check-v0.mjs",
    "prisma:generate": "npm run prisma:generate --workspace server",
    "prisma:migrate": "npm run prisma:migrate --workspace server",
    "prisma:seed": "npm run prisma:seed --workspace server",
    "prisma:test-tasks": "npm run prisma:test-tasks --workspace server"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
