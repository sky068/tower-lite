DATABASE_URL="postgresql://tower:tower@127.0.0.1:5432/tower?schema=public"
REDIS_URL="redis://127.0.0.1:6379"
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
APP_BASE_URL="http://localhost:5173"
API_PORT="4000"
NODE_ENV="development"
DEFAULT_ADMIN_EMAIL="admin@tower.local"
DEFAULT_ADMIN_PASSWORD="password123"
DEFAULT_ADMIN_NAME="系统管理员"
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
FEISHU_ENCRYPT_KEY=""
FEISHU_VERIFICATION_TOKEN=""

# 邮件发送器配置。未配置 SMTP 时，邮箱验证 / 密码重置邮件只会写入 EmailOutbox 开发邮件箱，不会真实发送。
SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASSWORD=""
MAIL_FROM="Tower Lite <noreply@example.com>"
# 邮件投递开关：0=按 SMTP 配置真实发送，1=强制不发送真实邮件。
# 本地自动测试会临时设为 1；正常本地调试和部署时，如果要收真实邮件请保持 0。
EMAIL_DELIVERY_DISABLED="0"
